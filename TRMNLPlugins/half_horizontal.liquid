<!--
  SQUIRREL BUDDY — Half Horizontal (~400x480)
  Large photo left, condition + compact values right
  Tighter spacing to prevent cutoff on TRMNL OG
-->

<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;700&display=swap');

  .sb-wrap {
    font-family: 'IBM Plex Mono', monospace;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 10px 14px 6px;
    box-sizing: border-box;
  }
  .sb-header {
    text-align: center;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    padding-bottom: 6px;
    text-transform: uppercase;
  }
  .sb-divider-thick { height: 1.5px; background: #000; width: 100%; }
  .sb-divider-thin { height: 1px; background: #000; width: 100%; }
  .sb-divider-light { height: 1px; background: rgba(0,0,0,0.2); width: 100%; }

  .sb-body {
    display: flex;
    flex: 1;
    gap: 12px;
    padding-top: 8px;
    padding-bottom: 4px;
    min-height: 0;
    overflow: hidden;
  }

  .sb-left {
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    width: 140px;
  }
  .sb-photo {
    width: 140px;
    flex: 1;
    border-radius: 12px;
    object-fit: cover;
  }

  .sb-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
    overflow: hidden;
  }
  .sb-condition-heading {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 2px 0;
  }
  .sb-section-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding-top: 2px;
  }
  .sb-val-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 0;
  }
  .sb-val-label {
    font-size: 8px;
    font-weight: 500;
    color: rgba(0,0,0,0.5);
    letter-spacing: 1px;
    text-transform: uppercase;
    width: 45px;
    flex-shrink: 0;
  }
  .sb-val-qual { flex: 1; }
  .sb-val-num { text-align: right; flex-shrink: 0; }
  .sb-footer {
    text-align: center;
    font-size: 9px;
    font-weight: 300;
    padding-top: 4px;
  }
</style>

<div class="sb-wrap">
  <div class="sb-header">Squirrel Buddy</div>
  <div class="sb-divider-thick"></div>

  <div class="sb-body">
    <div class="sb-left">
      <img class="sb-photo" src="https://raw.githubusercontent.com/danpinguc/Squirrel-Budy/refs/heads/main/Squirrel%20CloseUp.jpg" alt="squirrel" />
    </div>

    <div class="sb-right">
      {% if condition == "active" %}
        <div class="sb-condition-heading">● Likely Active</div>
      {% elsif condition == "cautious" %}
        <div class="sb-condition-heading">● Likely Cautious</div>
      {% elsif condition == "sheltering" %}
        <div class="sb-condition-heading">● Likely Sheltering</div>
      {% else %}
        <div class="sb-condition-heading">● --</div>
      {% endif %}

      <div class="sb-divider-thin"></div>
      <div class="sb-section-label">Sensors</div>

      <div class="sb-val-row">
        <span class="sb-val-label">Temp</span>
        <span class="sb-val-qual">{{ temp_label | default: "--" }}</span>
        <span class="sb-val-num">{{ temperature_f | default: "--" }}°F</span>
      </div>
      <div class="sb-divider-light"></div>
      <div class="sb-val-row">
        <span class="sb-val-label">Light</span>
        <span class="sb-val-qual">{{ light_label | default: "--" }}</span>
        <span class="sb-val-num">{{ light_lux | default: "--" }} lx</span>
      </div>
      <div class="sb-divider-light"></div>
      <div class="sb-val-row">
        <span class="sb-val-label">Sound</span>
        <span class="sb-val-qual">{{ sound_label | default: "--" }}</span>
        <span class="sb-val-num">{{ sound_level | default: "--" }} db</span>
      </div>
      <div class="sb-divider-light"></div>
      <div class="sb-val-row">
        <span class="sb-val-label">Press</span>
        <span class="sb-val-qual">{{ pressure_label | default: "--" }}</span>
        <span class="sb-val-num">{{ pressure_hpa | default: "--" }} hPa</span>
      </div>
    </div>
  </div>

  <div class="sb-divider-thick"></div>
  <div class="sb-footer">Updated {{ updated_at | default: "--:--" }}</div>
