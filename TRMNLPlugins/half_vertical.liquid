<!--
  SQUIRREL BUDDY — Half Vertical (~800x240)
  Left: compact sensor values (narrow, small text)
  Right: image + condition heading + breakdown (wider, larger text)
-->

<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;700&display=swap');

  .sb-wrap {
    font-family: 'IBM Plex Mono', monospace;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 8px 16px 6px;
    box-sizing: border-box;
  }
  .sb-header {
    text-align: center;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    padding-bottom: 6px;
    text-transform: uppercase;
  }
  .sb-divider-thick { height: 1.5px; background: #000; width: 100%; }
  .sb-divider-thin { height: 1px; background: #000; width: 100%; }
  .sb-divider-light { height: 1px; background: rgba(0,0,0,0.15); width: 100%; }

  .sb-body {
    display: flex;
    flex: 1;
    gap: 14px;
    padding-top: 6px;
    padding-bottom: 4px;
    min-height: 0;
    overflow: hidden;
  }

  /* Left column: compact sensors — narrow */
  .sb-left {
    width: 160px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
    overflow: hidden;
  }
  .sb-section-label {
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .sb-sensor {
    display: flex;
    flex-direction: column;
    padding: 1px 0;
  }
  .sb-sensor-label {
    font-size: 7px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(0,0,0,0.5);
  }
  .sb-sensor-data {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
    font-weight: 700;
  }

  /* Column separator */
  .sb-col-sep {
    width: 1.5px;
    background: #000;
    align-self: stretch;
    flex-shrink: 0;
  }

  /* Right column: image + condition + breakdown — wider */
  .sb-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 5px;
    min-width: 0;
    overflow: hidden;
  }
  .sb-condition-heading {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .sb-photo {
    width: 100%;
    height: 60px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
  }
  .sb-breakdown {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sb-breakdown-row {
    display: flex;
    gap: 6px;
    align-items: baseline;
    font-size: 11px;
    line-height: 1.3;
  }
  .sb-breakdown-label {
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    flex-shrink: 0;
    width: 50px;
  }
  .sb-breakdown-desc {
    font-weight: 300;
  }

  .sb-footer {
    text-align: center;
    font-size: 8px;
    font-weight: 300;
    padding-top: 4px;
  }
</style>

<div class="sb-wrap">
  <div class="sb-header">Squirrel Buddy</div>
  <div class="sb-divider-thick"></div>

  <div class="sb-body">

    <!-- Left Column: Sensor Values (narrow, small) -->
    <div class="sb-left">
      <div class="sb-section-label">Sensors</div>
      <div class="sb-divider-thin"></div>

      <div class="sb-sensor">
        <span class="sb-sensor-label">Temp</span>
        <div class="sb-sensor-data">
          <span>{{ temp_label | default: "--" }}</span>
          <span>{{ temperature_f | default: "--" }}°F</span>
        </div>
      </div>
      <div class="sb-divider-light"></div>
      <div class="sb-sensor">
        <span class="sb-sensor-label">Light</span>
        <div class="sb-sensor-data">
          <span>{{ light_label | default: "--" }}</span>
          <span>{{ light_lux | default: "--" }} lx</span>
        </div>
      </div>
      <div class="sb-divider-light"></div>
      <div class="sb-sensor">
        <span class="sb-sensor-label">Sound</span>
        <div class="sb-sensor-data">
          <span>{{ sound_label | default: "--" }}</span>
          <span>{{ sound_level | default: "--" }} db</span>
        </div>
      </div>
      <div class="sb-divider-light"></div>
      <div class="sb-sensor">
        <span class="sb-sensor-label">Pressure</span>
        <div class="sb-sensor-data">
          <span>{{ pressure_label | default: "--" }}</span>
          <span>{{ pressure_hpa | default: "--" }} hPa</span>
        </div>
      </div>
    </div>

    <!-- Separator -->
    <div class="sb-col-sep"></div>

    <!-- Right Column: Image + Conditions + Breakdown (wider, larger text) -->
    <div class="sb-right">
      <img class="sb-photo" src="https://raw.githubusercontent.com/danpinguc/Squirrel-Budy/refs/heads/main/Squirrel%20CloseUp.jpg" alt="squirrel" />

      <div class="sb-section-label">Conditions</div>
      <div class="sb-divider-thin"></div>
      {% if condition == "active" %}
        <div class="sb-condition-heading">● Likely Active</div>
      {% elsif condition == "cautious" %}
        <div class="sb-condition-heading">● Likely Cautious</div>
      {% elsif condition == "sheltering" %}
        <div class="sb-condition-heading">● Likely Sheltering</div>
      {% else %}
        <div class="sb-condition-heading">● --</div>
      {% endif %}

      <div class="sb-breakdown">
        <div class="sb-breakdown-row">
          <span class="sb-breakdown-label">Temp</span>
          <span class="sb-breakdown-desc">{{ temp_desc | default: "--" }}</span>
        </div>
        <div class="sb-breakdown-row">
          <span class="sb-breakdown-label">Light</span>
          <span class="sb-breakdown-desc">{{ light_desc | default: "--" }}</span>
        </div>
        <div class="sb-breakdown-row">
          <span class="sb-breakdown-label">Sound</span>
          <span class="sb-breakdown-desc">{{ sound_desc | default: "--" }}</span>
        </div>
        <div class="sb-breakdown-row">
          <span class="sb-breakdown-label">Press</span>
          <span class="sb-breakdown-desc">{{ pressure_desc | default: "--" }}</span>
        </div>
      </div>
    </div>

  </div>

  <div class="sb-divider-thick"></div>
  <div class="sb-footer">Updated {{ updated_at | default: "--:--" }}</div>
</div>